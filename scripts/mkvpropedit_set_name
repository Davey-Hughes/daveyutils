#!/usr/bin/env bash
#
# mkvpropedit_set_name - set each MKV's title tag from its filename.
#
# Usage: mkvpropedit_set_name [-d DELIM] [-f FIELD] [DIR]
#   -d DELIM   split the basename on DELIM to pick the title (requires -f)
#   -f FIELD   1-based field to use as the title
#   DIR        directory to search recursively (default: .)
#
# With no -d/-f, the title is the basename without its .mkv extension.
# Requires: mkvpropedit (mkvtoolnix)

die() { printf '%s\n' "$*" >&2; exit 1; }

# derive_title <filename> [delim] [field]
derive_title() {
    local base="${1##*/}"
    # Strip the extension case-insensitively: `find -iname '*.mkv'` matches any
    # case, so a case-sensitive `${base%.mkv}` would leave ".MKV" on the name and
    # bake it into the title tag. The explicit class is the exact inverse of the
    # find pattern -- unlike `${base%.*}` it can only ever remove a .mkv suffix,
    # never truncate a name that doesn't have one.
    base="${base%.[Mm][Kk][Vv]}"
    local delim="${2:-}" field="${3:-}" name="$base"
    if [[ -n "$delim" && -n "$field" ]]; then
        name="$(printf '%s' "$base" | cut -d"$delim" -f"$field")"
    fi
    # trim surrounding whitespace
    name="${name#"${name%%[![:space:]]*}"}"
    name="${name%"${name##*[![:space:]]}"}"
    printf '%s' "$name"
}

usage() {
    sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
}

main() {
    set -euo pipefail
    local delim="" field="" dir="."
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) usage; exit 0 ;;
            -d)
                [[ $# -ge 2 ]] || die "-d requires an argument"
                delim="$2"
                shift 2
                ;;
            -f)
                [[ $# -ge 2 ]] || die "-f requires an argument"
                field="$2"
                shift 2
                ;;
            --) shift; [[ $# -gt 0 ]] && { dir="$1"; shift; }; break ;;
            -*) die "unknown option: $1" ;;
            *) dir="$1"; shift ;;
        esac
    done
    # Both halves are needed or neither: -f alone was accepted and then silently
    # ignored by derive_title's guard, retitling every file with the full basename.
    [[ -n "$delim" && -z "$field" ]] && die "-d requires -f"
    [[ -n "$field" && -z "$delim" ]] && die "-f requires -d"
    command -v mkvpropedit >/dev/null 2>&1 || die "mkvpropedit is required (install mkvtoolnix)."
    [[ -d "$dir" ]] || die "not a directory: $dir"

    local ok=0 failed=0 f title
    while IFS= read -r -d '' f; do
        title="$(derive_title "$f" "$delim" "$field")"
        printf '%s -> %s\n' "$f" "$title"
        if mkvpropedit "$f" -e info --set "title=$title"; then
            ok=$((ok + 1))
        else
            printf 'WARN: mkvpropedit failed for %s\n' "$f" >&2
            failed=$((failed + 1))
        fi
    done < <(find "$dir" -iname '*.mkv' -print0)
    printf 'done: %d updated, %d failed\n' "$ok" "$failed"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
