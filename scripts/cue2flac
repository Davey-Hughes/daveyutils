#!/usr/bin/env bash
#
# cue2flac - Extract audio tracks from a CUE/BIN disc image as FLAC files.
#
# Usage: cue2flac <file.cue> [output_dir] [-t tracklist.txt]
#
# Requires: ffmpeg

set -euo pipefail

die() { printf '%s\n' "$*" >&2; exit 1; }

if [[ $# -lt 1 || "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: cue2flac <file.cue> [output_dir] [-t <tracklist>]"
    echo
    echo "Extracts audio tracks from a CUE/BIN disc image into FLAC files."
    echo "Data tracks (MODE1/MODE2) are skipped."
    echo
    echo "  output_dir      Directory for output files (default: current directory)"
    echo "  -t <tracklist>  Track names as a multi-line string (paste from VGMdb etc.)"
    echo "                  Leading track numbers and trailing durations are stripped."
    exit 0
fi

command -v ffmpeg >/dev/null 2>&1 || die "Error: ffmpeg is required but not found."

# Parse arguments.
cue_file=""
output_dir="."
tracklist_text=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -t) tracklist_text="$2"; shift 2 ;;
        *)
            if [[ -z "$cue_file" ]]; then
                cue_file="$1"
            else
                output_dir="$1"
            fi
            shift
            ;;
    esac
done

[[ -n "$cue_file" ]] || die "Error: No CUE file specified."
[[ -f "$cue_file" ]] || die "Error: CUE file not found: $cue_file"

cue_dir="$(cd "$(dirname "$cue_file")" && pwd)"
sector_size=2352

# Parse tracklist into an array of track names.
track_names=()
if [[ -n "$tracklist_text" ]]; then
    while IFS= read -r tl_line; do
        # Strip carriage returns
        tl_line="${tl_line%$'\r'}"
        # Skip empty lines
        [[ -z "${tl_line// /}" ]] && continue
        # Strip leading track number (e.g. "02", "2.", "02.", "2 -") and whitespace
        tl_line="$(printf '%s' "$tl_line" | sed -E 's/^[[:space:]]*[0-9]{1,3}[[:space:].\-]*//; s/^[[:space:]]*//')"
        # Strip trailing duration (e.g. "4:32", "11:36") and surrounding whitespace
        tl_line="$(printf '%s' "$tl_line" | sed -E 's/[[:space:]]+[0-9]+:[0-9]{2}[[:space:]]*$//')"
        track_names+=("$tl_line")
    done <<< "$tracklist_text"
fi

# Convert CUE timestamp (MM:SS:FF, 75 frames/sec) to a sector number.
msf_to_sectors() {
    local m s f
    IFS=: read -r m s f <<< "$1"
    echo $(( 10#$m * 60 * 75 + 10#$s * 75 + 10#$f ))
}

# Parse the CUE sheet.
img_file=""
tracks=()       # "type sector" pairs
cur_type=""

while IFS= read -r line; do
    # Strip leading/trailing whitespace and carriage returns
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%$'\r'}"

    if [[ "$line" =~ ^FILE[[:space:]]+\"([^\"]+)\" ]] || \
       [[ "$line" =~ ^FILE[[:space:]]+([^[:space:]]+) ]]; then
        img_file="${BASH_REMATCH[1]}"

    elif [[ "$line" =~ ^TRACK[[:space:]]+([0-9]+)[[:space:]]+(.+) ]]; then
        cur_type="${BASH_REMATCH[2]}"

    elif [[ "$line" =~ ^INDEX[[:space:]]+0?1[[:space:]]+([0-9]+:[0-9]+:[0-9]+) ]]; then
        tracks+=("${cur_type} $(msf_to_sectors "${BASH_REMATCH[1]}")")
    fi
done < "$cue_file"

[[ -n "$img_file" ]] || die "Error: No FILE directive found in CUE sheet."

# Resolve image path relative to the CUE file's directory.
if [[ "$img_file" != /* ]]; then
    img_file="$cue_dir/$img_file"
fi
[[ -f "$img_file" ]] || die "Error: Image file not found: $img_file"

img_size=$(stat -c%s "$img_file" 2>/dev/null || stat -f%z "$img_file")
total_sectors=$(( img_size / sector_size ))

# Validate tracklist count if provided.
num_tracks=${#tracks[@]}
if [[ ${#track_names[@]} -gt 0 && ${#track_names[@]} -ne $num_tracks ]]; then
    die "Error: Tracklist has ${#track_names[@]} names but CUE has $num_tracks tracks."
fi

mkdir -p "$output_dir"

extracted=0
skipped=0

for (( i = 0; i < num_tracks; i++ )); do
    read -r type start_sector <<< "${tracks[$i]}"
    track_num=$(( i + 1 ))

    if [[ "$type" != "AUDIO" ]]; then
        printf 'Track %02d: %s (skipping non-audio)\n' "$track_num" "$type"
        (( skipped++ )) || true
        continue
    fi

    # End sector is the start of the next track, or end of file.
    if (( i + 1 < num_tracks )); then
        read -r _ end_sector <<< "${tracks[$i+1]}"
    else
        end_sector=$total_sectors
    fi

    num_sectors=$(( end_sector - start_sector ))
    duration_secs=$(( num_sectors / 75 ))
    duration_str=$(printf '%d:%02d' $(( duration_secs / 60 )) $(( duration_secs % 60 )))

    # Build metadata args.
    metadata_args=(-metadata track="$track_num/$num_tracks")
    title=""
    if [[ ${#track_names[@]} -gt 0 ]]; then
        title="${track_names[$i]}"
        metadata_args+=(-metadata title="$title")
    fi

    if [[ -n "$title" ]]; then
        # Sanitize title for use as filename (replace / and NUL)
        safe_title="${title//\//_}"
        outfile="$output_dir/$(printf '%02d' "$track_num") - ${safe_title}.flac"
    else
        outfile="$output_dir/$(printf '%02d' "$track_num").flac"
    fi

    if [[ -n "$title" ]]; then
        printf 'Track %02d: "%s" (~%s) -> %s\n' "$track_num" "$title" "$duration_str" "$outfile"
    else
        printf 'Track %02d: (~%s) -> %s\n' "$track_num" "$duration_str" "$outfile"
    fi

    dd if="$img_file" bs=$sector_size skip="$start_sector" count="$num_sectors" status=none | \
        ffmpeg -y -hide_banner -loglevel error \
            -f s16le -ar 44100 -ac 2 \
            -i pipe:0 \
            "${metadata_args[@]}" \
            "$outfile"

    (( extracted++ )) || true
done

echo
echo "Done: $extracted track(s) extracted, $skipped skipped."
