#!/usr/bin/env bash
#
# video_pcm_to_flac - convert PCM audio streams in video files to FLAC
# (or vice versa), batching over every file matching a glob.
#
# Usage: video_pcm_to_flac [OPTIONS] [-g GLOB] [-o OUTDIR] [-m N]
#   -g, --glob GLOB        files to match (default: *.mkv)
#   -o, --output-dir DIR   output root; a "<show>/<input>" tree is written
#                          under it, where <show> is the current dir's
#                          basename (default: ./ffmpeg_output)
#   -m, --max-files N      stop after converting N files
#       --dry-run          print what would happen; don't run ffmpeg
#       --only-output      suppress the per-file chatter, print only paths
#       --copy-first       remux to matroska in a pipe before re-encoding
#                          audio, instead of doing it in one ffmpeg pass
#       --flac-to-pcm      convert FLAC audio streams to pcm_s16le instead
#                          of the default PCM -> FLAC direction
#
# Requires: fd, ffprobe, ffmpeg

die() { printf '%s\n' "$*" >&2; exit 1; }

# select_streams <ffprobe_csv> <direction>
# ffprobe_csv: newline-separated "index,codec_name[,title]" rows (as
# produced by `ffprobe -show_entries stream=index,codec_name:stream_tags=title
# -of csv=print_section=0`). direction is "pcm2flac" or "flac2pcm".
# Echoes ffmpeg "-c:<index> <target-codec>" args (space-separated, no
# trailing space) for every stream that matches; echoes nothing if none do.
select_streams() {
    local csv="$1" direction="$2"
    local -a args=()
    local line index codec
    while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        IFS=',' read -r index codec _ <<<"$line"
        if [[ "$direction" == "pcm2flac" && "$codec" =~ ^pcm_ ]]; then
            args+=("-c:$index" "flac")
        elif [[ "$direction" == "flac2pcm" && "$codec" == "flac" ]]; then
            args+=("-c:$index" "pcm_s16le")
        fi
    done <<<"$csv"
    printf '%s' "${args[*]:-}"
}

# stream_metadata <array-name> <ffprobe_csv> <direction>
# Populates the named array with `-metadata:s:<idx>` `title=<swapped>` pairs
# for each converted stream that has a title tag, swapping PCM<->FLAC in the
# text (first occurrence only, matching fish's `string replace`).
stream_metadata() {
    local -n _out="$1"
    _out=()
    local csv="$2" direction="$3"
    local line index codec title
    while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        IFS=',' read -r index codec title <<<"$line"
        if [[ "$direction" == "pcm2flac" && "$codec" =~ ^pcm_ ]]; then
            [[ -n "$title" ]] && _out+=("-metadata:s:$index" "title=${title/PCM/FLAC}")
        elif [[ "$direction" == "flac2pcm" && "$codec" == "flac" ]]; then
            [[ -n "$title" ]] && _out+=("-metadata:s:$index" "title=${title/FLAC/PCM}")
        fi
    done <<<"$csv"
}

# output_path <input> <outdir> <show> -> "<outdir>/<show>/<input>",
# with any leading "./" on input dropped.
output_path() {
    local input="$1" outdir="$2" show="$3"
    printf '%s/%s/%s' "$outdir" "$show" "${input#./}"
}

usage() {
    sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
}

main() {
    set -euo pipefail

    local glob="*.mkv" outdir="./ffmpeg_output" max_files=""
    local dry_run=0 only_output=0 copy_first=0 flac_to_pcm=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) usage; exit 0 ;;
            --dry-run) dry_run=1; shift ;;
            --only-output) only_output=1; shift ;;
            --copy-first) copy_first=1; shift ;;
            --flac-to-pcm) flac_to_pcm=1; shift ;;
            -g|--glob) glob="${2:?"$1 requires an argument"}"; shift 2 ;;
            -o|--output-dir) outdir="${2:?"$1 requires an argument"}"; shift 2 ;;
            -m|--max-files) max_files="${2:?"$1 requires an argument"}"; shift 2 ;;
            --) shift; break ;;
            -*) die "unknown option: $1" ;;
            *) shift ;;
        esac
    done

    command -v fd >/dev/null 2>&1 || die "fd is required."
    command -v ffprobe >/dev/null 2>&1 || die "ffprobe is required."
    command -v ffmpeg >/dev/null 2>&1 || die "ffmpeg is required."

    local direction="pcm2flac"
    [[ "$flac_to_pcm" -eq 1 ]] && direction="flac2pcm"

    local show; show="$(basename "$PWD")"

    local ok=0 failed=0 files_seen=0
    local -a error_files=()

    while IFS= read -r -d '' input; do
        if [[ -n "$max_files" && "$files_seen" -ge "$max_files" ]]; then
            break
        fi

        [[ "$only_output" -eq 1 ]] || printf '%s\n' "$input"

        local csv
        if ! csv="$(ffprobe -v error -select_streams a \
                -show_entries stream=index,codec_name:stream_tags=title \
                -of csv=print_section=0 "$input")"; then
            printf 'WARN: ffprobe failed for %s\n' "$input" >&2
            error_files+=("$input")
            failed=$((failed + 1))
            continue
        fi

        local streams; streams="$(select_streams "$csv" "$direction")"
        local -a audio_streams=()
        [[ -n "$streams" ]] && read -ra audio_streams <<<"$streams"

        if [[ "${#audio_streams[@]}" -eq 0 ]]; then
            if [[ "$only_output" -eq 0 ]]; then
                if [[ "$direction" == "flac2pcm" ]]; then
                    printf '\tNo FLAC audio streams found in %s\n\n' "$input"
                else
                    printf '\tNo PCM audio streams found in %s\n\n' "$input"
                fi
            fi
            continue
        fi

        files_seen=$((files_seen + 1))

        local -a metadata=()
        stream_metadata metadata "$csv" "$direction"
        local out; out="$(output_path "$input" "$outdir" "$show")"

        [[ "$only_output" -eq 0 ]] && printf '\t'
        printf '%s\n' "$input"

        if [[ "$dry_run" -eq 1 ]]; then
            printf '\twould write: %s\n' "$out"
            continue
        fi

        if [[ -e "$out" ]]; then
            printf '\tOutput file already exists, skipping: %s\n' "$out"
            continue
        fi

        mkdir -p "$(dirname "$out")"

        if [[ "$copy_first" -eq 1 ]]; then
            if ffmpeg -n -nostdin -hide_banner -v error -stats -i "$input" \
                    -map 0 -c copy -f matroska pipe: \
                | ffmpeg -n -hide_banner -v error -stats -f matroska -i pipe: \
                    -map 0 "${metadata[@]}" -c copy "${audio_streams[@]}" "$out"; then
                ok=$((ok + 1))
            else
                printf 'WARN: ffmpeg failed for %s\n' "$input" >&2
                rm -f "$out"
                error_files+=("$input")
                failed=$((failed + 1))
            fi
        else
            if ffmpeg -n -nostdin -hide_banner -v error -stats -i "$input" \
                    -map 0 "${metadata[@]}" -c copy "${audio_streams[@]}" "$out"; then
                ok=$((ok + 1))
            else
                printf 'WARN: ffmpeg failed for %s\n' "$input" >&2
                rm -f "$out"
                error_files+=("$input")
                failed=$((failed + 1))
            fi
        fi

        [[ "$only_output" -eq 1 ]] || echo
    done < <(fd --ignore-case --glob "$glob" -0)

    printf 'done: %d converted, %d failed\n' "$ok" "$failed"

    if [[ "${#error_files[@]}" -gt 0 ]]; then
        printf 'Errored files:\n'
        printf '%s\n' "${error_files[@]}"
    fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
