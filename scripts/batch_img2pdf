#!/usr/bin/env bash
#
# batch_img2pdf - unzip image archives in a directory and make one PDF per folder.
#
# Usage: batch_img2pdf [-o OUTDIR] [--clean] MAINDIR
#   -o OUTDIR   where PDFs are written (default: ./pdfs)
#   --clean     delete each source image folder, but only when it is fully
#               covered by its PDF (no subdirectories, no extra files); a
#               folder with nested content the PDF didn't cover is kept
#   MAINDIR     directory containing the *.zip archives / image folders
#
# Requires: unar, img2pdf, file

die() { printf '%s\n' "$*" >&2; exit 1; }

# folder_fully_covered <dir> <n-images>
# True only when <dir> has no subdirectories and holds exactly <n-images>
# entries, i.e. everything in it went into the PDF. --clean deletes the whole
# tree, so a folder with nested content the PDF never covered must NOT be
# removed.
#
# The count is `! -type d`, not `-type f`: `-type f` matches neither a
# symlink-to-file nor a symlink-to-dir, so a symlink was invisible to BOTH
# sides of this check -- the image scan skipped it (it never reached the PDF)
# and the total skipped it too, so total == n said "fully covered" and the link
# was deleted. `! -type d` counts links (and fifos, sockets) as the uncovered
# entries they are, which keeps the folder. The subdirectory probe stays: an
# EMPTY subdir adds nothing to the count but is still uncovered content.
folder_fully_covered() {
    local dir="$1" n="$2"
    [[ -z "$(find "$dir" -mindepth 1 -type d -print -quit)" ]] || return 1
    local total
    total="$(find "$dir" ! -type d | wc -l)"
    [[ "$total" -eq "$n" ]]
}

# uncovered_entries <dir>
# The entries in <dir> that did NOT go into its PDF, one path per line: every
# top-level subdirectory (the PDF only covered top-level images, so a subdir's
# whole tree is uncovered) and every top-level entry the image scan skipped.
# Mirrors that scan exactly -- an entry is covered iff it is a regular file
# (`find -type f`, which excludes symlinks) that `file` reports as an image.
#
# This names what kept a folder. A single .DS_Store is enough to keep one
# forever, and .DS_Store is ubiquitous in macOS-authored zips, so "it holds
# files the PDF does not cover" left the user with no way to see why. Naming
# the entries -- rather than ignoring a known-junk set -- keeps --clean exactly
# as eager as the coverage check proves is safe.
uncovered_entries() {
    local dir="$1" e
    while IFS= read -r -d '' e; do
        printf '%s\n' "$e"
    done < <(find "$dir" -mindepth 1 -maxdepth 1 -type d -print0)
    while IFS= read -r -d '' e; do
        if [[ -L "$e" ]] || ! file --mime-type -b "$e" 2>/dev/null | grep -q '^image/'; then
            printf '%s\n' "$e"
        fi
    done < <(find "$dir" -mindepth 1 -maxdepth 1 ! -type d -print0)
    return 0
}

OUTDIR="./pdfs"
CLEAN=0
MAINDIR=""

# parse_args <args...> -> sets OUTDIR/CLEAN/MAINDIR; echoes "OUTDIR|CLEAN|MAINDIR".
parse_args() {
    OUTDIR="./pdfs"; CLEAN=0; MAINDIR=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) MAINDIR="__help__"; shift ;;
            -o) OUTDIR="${2:?}"; shift 2 ;;
            --clean) CLEAN=1; shift ;;
            --) shift; [[ $# -gt 0 ]] && { MAINDIR="$1"; shift; }; break ;;
            -*) die "unknown option: $1" ;;
            *) MAINDIR="$1"; shift ;;
        esac
    done
    printf '%s|%s|%s' "$OUTDIR" "$CLEAN" "$MAINDIR"
}

usage() {
    sed -n '2,11p' "$0" | sed 's/^# \{0,1\}//'
}

main() {
    set -euo pipefail
    parse_args "$@" >/dev/null
    [[ "$MAINDIR" == "__help__" ]] && { usage; exit 0; }
    [[ -n "$MAINDIR" ]] || { usage; exit 1; }
    command -v unar >/dev/null 2>&1 || die "unar is required."
    command -v img2pdf >/dev/null 2>&1 || die "img2pdf is required."
    command -v file >/dev/null 2>&1 || die "file is required."
    [[ -d "$MAINDIR" ]] || die "not a directory: $MAINDIR"

    mkdir -p "$OUTDIR"

    # Unzip every archive (in parallel), then wait for all of them.
    local -a pids=()
    local z
    for z in "$MAINDIR"/*.zip; do
        [[ -e "$z" ]] || break
        unar -q -o "$MAINDIR" "$z" &
        pids+=("$!")
    done
    local pid
    for pid in "${pids[@]}"; do
        wait "$pid" || printf 'WARN: an archive failed to extract\n' >&2
    done

    # One PDF per image subdirectory. --clean only removes a folder whose
    # own PDF just succeeded; a failed conversion always keeps its source.
    local ok=0 failed=0
    local d
    while IFS= read -r -d '' d; do
        local -a images=()
        local img
        while IFS= read -r -d '' img; do
            if file --mime-type -b "$img" | grep -q '^image/'; then images+=("$img"); fi
        done < <(find "$d" -maxdepth 1 -type f -print0 | sort -z)
        [[ ${#images[@]} -gt 0 ]] || continue
        local name; name="$(basename "$d")"
        printf 'pdf: %s -> %s/%s.pdf\n' "$d" "$OUTDIR" "$name"
        if img2pdf "${images[@]}" -o "$OUTDIR/$name.pdf"; then
            ok=$((ok + 1))
            if [[ "$CLEAN" -eq 1 ]]; then
                if folder_fully_covered "$d" "${#images[@]}"; then
                    rm -rf "$d"
                else
                    printf 'WARN: kept %s: it holds files the PDF does not cover:\n' "$d" >&2
                    uncovered_entries "$d" | sed 's/^/  /' >&2
                fi
            fi
        else
            printf 'WARN: img2pdf failed for %s\n' "$d" >&2
            failed=$((failed + 1))
        fi
    done < <(find "$MAINDIR" -mindepth 1 -maxdepth 1 -type d -print0)
    printf 'done: %d pdfs, %d failed\n' "$ok" "$failed"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
